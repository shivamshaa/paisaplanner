# ─────────────────────────────────────────────
# .env.example – Money Manager
#
# Copy this file to .env inside the /server directory:
#   cp .env.example server/.env
#
# Then fill in your values.
# ─────────────────────────────────────────────

# ── Gemini AI (free tier) ──────────────────────
# Get your free API key in 60 seconds — no credit card needed:
#   1. Go to https://aistudio.google.com/app/apikey
#   2. Sign in with your Google account
#   3. Click "Create API Key"
#   4. Paste it below
#
# Free tier limits: 15 requests/min, 1,500 requests/day
# This is MORE than enough for personal use.
#
# If you leave this blank or as the placeholder value,
# the app will still work — it'll use a built-in rule-based
# explanation instead of AI. Everything else works normally.
GEMINI_API_KEY=AIzaSyB5KO8oDsQ-507HOn4ID21SJDaX_86xPOI
# ── Server config ──────────────────────────────
# Port the Express server listens on (default: 3001)
PORT=3001

# ── Frontend URL (for CORS) ────────────────────
# This is the URL of your React frontend.
# In development, Vite runs on 5173 by default.
# Change this if you deploy to a different URL.
CLIENT_URL=http://localhost:5173
