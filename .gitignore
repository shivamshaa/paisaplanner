# ─────────────────────────────────────────────
#  .gitignore — Paisa Planner / Money Manager
# ─────────────────────────────────────────────

# ── Environment & secrets ──────────────────────
# NEVER commit API keys or env files
.env
.env.local
.env.development
.env.production
.env.*.local
# Keep .env.example — it's a safe template with no real values
!.env.example
!**/.env.example

# ── Node modules ───────────────────────────────
node_modules/
**/node_modules/

# ── Build output ───────────────────────────────
dist/
build/
**/dist/
**/build/

# ── Vite ───────────────────────────────────────
.vite/
**/.vite/

# ── TypeScript ─────────────────────────────────
*.tsbuildinfo
**/*.tsbuildinfo

# ── Logs ───────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS files ───────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor & IDE ───────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Package manager locks ──────────────────────
# Uncomment the one you DON'T use (keep the one you do)
# yarn.lock
# package-lock.json

# ── Test & coverage ────────────────────────────
coverage/
.nyc_output/

# ── Misc ───────────────────────────────────────
*.local
.cache/
tmp/
temp/